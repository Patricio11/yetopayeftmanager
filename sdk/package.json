{
  "name": "@yetopayeft/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for YETOPAYEFT Payment Gateway",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "yetopayeft",
    "payment",
    "gateway",
    "eft",
    "south-africa",
    "payments",
    "sdk"
  ],
  "author": "YETOPAYEFT",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yetopayeft/sdk"
  },
  "bugs": {
    "url": "https://github.com/yetopayeft/sdk/issues"
  },
  "homepage": "https://yetopayeft.com",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
